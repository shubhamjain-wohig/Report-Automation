# ============================================
# Option 1: Google Gemini API (Default)
# ============================================
# GOOGLE_API_KEY=your_google_api_key_here
# export GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ============================================
# Option 2: Groq API (Alternative - no rate limits!)
# ============================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Google Drive OAuth (personal Drive)
# ============================================
# Path to OAuth client secret JSON (Desktop app credential)
# GOOGLE_OAUTH_CLIENT_SECRET_JSON=/path/to/oauth_client_secret.json
# Where to store generated OAuth token after first login
# GOOGLE_OAUTH_TOKEN_JSON=./google_oauth_token.json
# Auth mode: local_server (recommended) or console
# GOOGLE_OAUTH_AUTH_MODE=local_server

# ============================================
# Google Sheets Service Account Credentials (for uploading to Google Sheets)
# ============================================
# Option1: Path to service account JSON file
# GOOGLE_SHEETS_CREDENTIALS_JSON=/path/to/service_account.json
# Option2: Base64-encoded service account JSON
# GOOGLE_SHEETS_CREDENTIALS_B64=base64_encoded_json_here

# Optional: Google Drive folder ID to place the sheet in
# GOOGLE_SHEETS_PARENT_FOLDER_ID=your_folder_id_here

# Optional: Google Drive folder ID to place the Slides report in
# GOOGLE_SLIDES_PARENT_FOLDER_ID=your_folder_id_here

# Optional: Comma-separated emails to share the Google Sheet with
# GOOGLE_SHEETS_SHARE_WITH=user1@example.com,user2@example.com
# GOOGLE_SHEETS_SHARE_ROLE=writer

# Optional: Make Google Sheet publicly readable (true/false)
# GOOGLE_SHEETS_MAKE_PUBLIC=false

# Output directory for generated files
OUTPUT_DIR=./outputs

# File server port
FILE_SERVER_PORT=8000

# ADK web UI port
ADK_PORT=8080
